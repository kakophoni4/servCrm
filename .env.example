POSTGRES_USER=crm
POSTGRES_PASSWORD=change-me
POSTGRES_DB=crm
JWT_SECRET=change-me-long-random
JWT_EXPIRES_IN=7d

# HTTP по IP (подставь свой IP VPS). Домен не обязателен.
# Пустой PUBLIC_API_URL = браузер ходит на тот же host (/api через Caddy).
PUBLIC_API_URL=
CORS_ORIGIN=http://ВАШ_IP

# TG-токен задаётся из админки (Настройки → Telegram-бот). Env — необязательный fallback.
# Бот слушает сообщения через getUpdates (polling) — домен и BASE_URL не нужны.
TELEGRAM_BOT_TOKEN=

# Опционально: публичный HTTPS для будущего webhook. Сейчас не используется.
BASE_URL=
