POSTGRES_USER=crm
POSTGRES_PASSWORD=change-me
POSTGRES_DB=crm
JWT_SECRET=change-me-long-random
JWT_EXPIRES_IN=7d

# HTTP по IP (подставь свой IP VPS). Домен не обязателен.
# Пустой PUBLIC_API_URL = браузер ходит на тот же host (/api через Caddy).
PUBLIC_API_URL=
CORS_ORIGIN=http://ВАШ_IP

# TG-токен теперь задаётся из админки (Настройки → Бот Telegram, только владелец).
# Эта переменная — необязательный fallback, если токен не задан в БД.
TELEGRAM_BOT_TOKEN=

# Публичный HTTPS-адрес API для Telegram setWebhook (без хвоста /api).
# Пример: https://crm.example.com  → webhook = BASE_URL/api/bot/webhook/<secret>
BASE_URL=
